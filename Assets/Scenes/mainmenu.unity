  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Game ini adalah petualangan platformer 2D di mana pemain mengendalikan
    karakter utama untuk melewati rintangan, melompat di atas musuh, dan mengumpulkan
    koin. Setiap level dirancang dengan tantangan berbeda, mulai dari platform bergerak,
    jebakan, hingga musuh yang harus dihindari.\n\nCara Bermain:\n-Gunakan tombol
    \u2190 \u2192 untuk bergerak ke kiri dan kanan.\n-Tekan tombol Space untuk melompat.\n-Kumpulkan
    koin sebanyak mungkin untuk menambah skor.\n-Capai bendera akhir level untuk
    menyelesaikan tahap dan lanjut ke level berikutnya."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
